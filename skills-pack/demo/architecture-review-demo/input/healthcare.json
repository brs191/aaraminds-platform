{
  "system_name": "patient-care-coordination-platform",
  "description": "Patient-facing and clinician-facing care coordination platform for a multi-site outpatient network. Provides appointment scheduling, electronic patient records, lab order and result management, clinician messaging, and patient billing. Subject to HIPAA: PHI handling, fine-grained access control, audit of every access, and tamper-evident record history.",
  "deployment_target": "container_apps",
  "api_style": "rest",
  "versioning_strategy": "header",
  "constraints": [
    "HIPAA compliance: PHI must be encrypted at rest and in transit, access audited per record",
    "every patient record access must be auditable for at least 7 years",
    "tamper-evident history of patient record changes required for medical-legal review",
    "clinician identity must be verifiable per request (no shared service tokens)",
    "regional residency: PHI does not leave the deployment region"
  ],
  "non_functional_requirements": {
    "availability_target": "99.9",
    "latency_p99_ms": 800
  },
  "patterns": [
    "api_gateway",
    "event_sourcing",
    "cqrs",
    "async_messaging",
    "idempotent_consumer",
    "zero_trust",
    "service_mesh",
    "transactional_outbox",
    "document_data",
    "observability",
    "identity",
    "audit_logging",
    "rolling_deployment"
  ],
  "teams": [
    {"name": "clinical-systems-team"},
    {"name": "patient-experience-team"},
    {"name": "platform-team"}
  ],
  "data_stores": [
    {"name": "patient-records-event-store", "kind": "postgres", "classification": "phi", "encrypted": true},
    {"name": "patient-records-read-model", "kind": "cosmos", "classification": "phi", "encrypted": true},
    {"name": "scheduling-db", "kind": "postgres", "classification": "phi", "encrypted": true},
    {"name": "lab-results-store", "kind": "postgres", "classification": "phi", "encrypted": true},
    {"name": "billing-db", "kind": "postgres", "classification": "pii", "encrypted": true},
    {"name": "provider-directory-db", "kind": "postgres", "encrypted": true},
    {"name": "audit-log-store", "kind": "postgres", "classification": "audit", "encrypted": true},
    {"name": "session-cache", "kind": "redis", "encrypted": true}
  ],
  "services": [
    {
      "name": "api-gateway",
      "business_capability": "external API governance, mTLS termination, and per-request identity validation",
      "criticality": "high",
      "type": "gateway",
      "stateful": false,
      "replicated": true,
      "owns_data": [],
      "depends_on": ["auth-service", "patient-records-service", "scheduling-service", "lab-results-service", "billing-service"],
      "team": "platform-team",
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/",
      "resources": []
    },
    {
      "name": "auth-service",
      "business_capability": "patient and clinician authentication, role-aware session issuance",
      "criticality": "high",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["identities", "roles", "sessions"],
      "depends_on": [],
      "team": "platform-team",
      "data_stores": ["session-cache"],
      "resilience": ["timeout", "retry"],
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/auth",
      "resources": [
        {"name": "tokens", "operations": ["create"], "versioned": true},
        {"name": "sessions", "operations": ["get", "delete"], "versioned": true}
      ]
    },
    {
      "name": "patient-records-service",
      "business_capability": "patient record write side (event-sourced clinical history)",
      "criticality": "high",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["patient_record_events"],
      "depends_on": ["auth-service"],
      "team": "clinical-systems-team",
      "data_stores": ["patient-records-event-store"],
      "resilience": ["timeout", "retry", "outbox"],
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/records",
      "resources": [
        {"name": "records", "operations": ["get", "create", "update"], "paginated": true, "versioned": true},
        {"name": "encounters", "operations": ["list", "get", "create"], "paginated": true, "versioned": true}
      ]
    },
    {
      "name": "patient-records-read-service",
      "business_capability": "patient record read side (CQRS projection for clinician queries)",
      "criticality": "high",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["patient_record_projections"],
      "depends_on": ["auth-service"],
      "consumes_events_from": ["patient-records-service"],
      "team": "clinical-systems-team",
      "data_stores": ["patient-records-read-model"],
      "resilience": ["timeout"],
      "has_dashboards": true,
      "has_alerts": false
    },
    {
      "name": "scheduling-service",
      "business_capability": "appointment scheduling for patients and clinicians",
      "criticality": "medium",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["appointments", "appointment_slots"],
      "depends_on": ["auth-service", "provider-directory-service"],
      "team": "patient-experience-team",
      "data_stores": ["scheduling-db"],
      "resilience": ["timeout", "retry"],
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/scheduling",
      "resources": [
        {"name": "appointments", "operations": ["list", "get", "create", "update", "delete"], "paginated": true, "versioned": true}
      ]
    },
    {
      "name": "lab-results-service",
      "business_capability": "lab order placement and result ingestion (HL7 / FHIR)",
      "criticality": "high",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["lab_orders", "lab_results"],
      "depends_on": ["auth-service", "patient-records-service"],
      "consumes_events_from": ["external-lab-gateway"],
      "team": "clinical-systems-team",
      "data_stores": ["lab-results-store"],
      "resilience": ["timeout", "retry", "circuit_breaker"],
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/labs",
      "resources": [
        {"name": "orders", "operations": ["list", "get", "create"], "paginated": true, "versioned": true},
        {"name": "results", "operations": ["list", "get"], "paginated": true, "versioned": true}
      ]
    },
    {
      "name": "external-lab-gateway",
      "business_capability": "inbound integration with external lab partners over HL7/FHIR",
      "criticality": "medium",
      "type": "worker",
      "stateful": false,
      "replicated": true,
      "owns_data": [],
      "depends_on": [],
      "team": "clinical-systems-team",
      "data_stores": [],
      "resilience": ["retry", "circuit_breaker"],
      "has_dashboards": false,
      "has_alerts": true
    },
    {
      "name": "provider-directory-service",
      "business_capability": "clinician and care-team directory",
      "criticality": "medium",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["providers", "provider_credentials"],
      "depends_on": ["auth-service"],
      "team": "patient-experience-team",
      "data_stores": ["provider-directory-db"],
      "resilience": ["timeout"],
      "has_dashboards": false,
      "has_alerts": false
    },
    {
      "name": "billing-service",
      "business_capability": "insurance claim submission and patient billing",
      "criticality": "medium",
      "type": "api",
      "stateful": false,
      "replicated": true,
      "owns_data": ["claims", "invoices", "payments"],
      "depends_on": ["auth-service", "patient-records-read-service"],
      "consumes_events_from": ["patient-records-service"],
      "team": "patient-experience-team",
      "data_stores": ["billing-db"],
      "resilience": ["timeout", "retry", "outbox"],
      "has_dashboards": true,
      "has_alerts": true,
      "auth": "oauth2",
      "base_path": "/billing",
      "resources": [
        {"name": "claims", "operations": ["list", "get", "create"], "paginated": true, "versioned": true},
        {"name": "invoices", "operations": ["list", "get"], "paginated": true, "versioned": true}
      ]
    },
    {
      "name": "audit-service",
      "business_capability": "HIPAA-grade audit logging of every PHI access",
      "criticality": "high",
      "type": "worker",
      "stateful": false,
      "replicated": true,
      "owns_data": ["audit_entries"],
      "depends_on": [],
      "consumes_events_from": ["auth-service", "patient-records-service", "patient-records-read-service", "lab-results-service", "billing-service"],
      "team": "platform-team",
      "data_stores": ["audit-log-store"],
      "resilience": ["retry"],
      "has_dashboards": true,
      "has_alerts": true
    },
    {
      "name": "notification-service",
      "business_capability": "appointment reminders, lab-result notifications, billing notices",
      "criticality": "low",
      "type": "worker",
      "stateful": false,
      "replicated": true,
      "owns_data": [],
      "depends_on": [],
      "consumes_events_from": ["scheduling-service", "lab-results-service", "billing-service"],
      "team": "patient-experience-team",
      "data_stores": [],
      "has_dashboards": false,
      "has_alerts": true
    }
  ]
}
