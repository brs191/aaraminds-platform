%% Repo Context Platform - Architecture (hybrid view, platform-level)
%% AaraMinds AI Engineering Architect v1.2
flowchart TB
    %% --- Node & layer definitions first, edges last ---
    subgraph TRIG["Layer 1 - Source & Trigger"]
        REPOS["Portfolio of repos<br/>Spring Boot - React - Postgres - Mongo"]
        EV["Merge-to-main webhook<br/>Scheduled sweep / Manual"]
    end

    subgraph PARSE["Layer 2 - Ingestion & Parsing (deterministic - no LLM)"]
        CLONE["Clone repo (read-only)"]
        FACTS["Structural facts file<br/>module map - API surface - data model<br/>+ parser coverage matrix"]
    end

    subgraph GEN["Layer 3 - Context Generation"]
        LLM["LLM via GenAI gateway<br/>grounded in facts file<br/>output to standard C4 template"]
    end

    REVIEW{"Layer 4 - Human Review<br/>repo owner approves / rejects<br/>DOC enforcement point"}

    subgraph PUB["Layer 5 - Store & Publish"]
        PORTAL["Developer portal<br/>Backstage TechDocs"]
        DOCS["docs/context + CONTEXT.md<br/>committed back to repo"]
    end

    DEVS["Human developers<br/>onboarding - navigation - architecture"]

    subgraph FRESH["Layer 6 - Freshness & Drift (deterministic)"]
        DRIFT["Track approved commit<br/>detect drift - flag stale - requeue"]
    end

    subgraph GOV["Governance & Identity (control plane)"]
        G1["Read-only repo-scoped access - Entra ID / Git org"]
        G2["Ingestion denylist - secret scan - PII redaction"]
        G3["Audit log: who generated / approved / source commit"]
    end

    subgraph OBSP["Observability & Feedback (control plane)"]
        OBS["Coverage - freshness - review-queue health<br/>generation-quality proxy - usage - cost"]
    end

    %% --- Primary flow ---
    REPOS --> EV
    EV --> CLONE
    CLONE --> FACTS
    FACTS --> LLM
    LLM --> REVIEW
    REVIEW -- "approve with edits" --> PORTAL
    REVIEW -- "approve with edits" --> DOCS
    REVIEW -- "reject / change request" --> LLM
    PORTAL --> DEVS
    DOCS --> DEVS

    %% --- Feedback & freshness loops ---
    DEVS -. "feedback: thumbs / this-is-wrong" .-> OBS
    PORTAL --> DRIFT
    DOCS --> DRIFT
    DRIFT -. "drift threshold crossed" .-> EV

    %% --- Control planes ---
    GOV -. governs .-> PARSE
    GOV -. governs .-> GEN
    GOV -. governs .-> REVIEW
    OBSP -. monitors .-> GEN
    OBSP -. monitors .-> REVIEW
    OBSP -. monitors .-> FRESH
