{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaraminds.ai/schemas/data-evidence-contract.schema.json",
  "title": "AAP Data and Evidence Contract",
  "description": "Source-of-truth mapping and evidence rules per BRD v2.1 BR-007 / BR-011.",
  "type": "object",
  "required": ["agent_id", "contract_version", "data_domains", "evidence_rules"],
  "properties": {
    "agent_id": { "type": "string" },
    "contract_version": { "type": "string" },
    "data_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["domain", "authoritative_source", "record_type", "classification"],
        "properties": {
          "domain": { "type": "string" },
          "authoritative_source": { "type": "string" },
          "record_type": { "type": "string", "enum": ["actionable", "read-only", "read-only-after-write", "approval-gated-write"] },
          "classification": { "type": "string", "enum": ["public", "internal", "client-confidential", "pii"] },
          "staleness_note": { "type": "string", "description": "Mark cached, derived, or conflicting data." }
        }
      }
    },
    "evidence_rules": {
      "type": "object",
      "required": ["factual_claims_require_citation", "citation_format", "uncited_output_behavior"],
      "properties": {
        "factual_claims_require_citation": { "type": "boolean" },
        "citation_format": { "type": "string" },
        "uncited_output_behavior": { "type": "string", "enum": ["block", "flag", "downgrade-to-assumption"] },
        "memory_write_citation_required": { "type": "boolean", "description": "Aligns with memory citation enforcement release gate." }
      }
    }
  }
}
