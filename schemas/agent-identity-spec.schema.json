{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaraminds.ai/schemas/agent-identity-spec.schema.json",
  "title": "AAP Agent Identity Specification",
  "type": "object",
  "required": ["agent_id", "spec_version", "principal", "credential", "scopes", "lifecycle"],
  "properties": {
    "agent_id": { "type": "string" },
    "spec_version": { "type": "string" },
    "principal": {
      "type": "object",
      "required": ["principal_type", "idp", "distinct_from_user"],
      "properties": {
        "principal_type": { "type": "string", "enum": ["agent-identity", "workload-identity", "managed-identity"] },
        "idp": { "type": "string", "description": "e.g. entra-id; [VERIFY per implementation]" },
        "principal_ref": { "type": "string", "description": "IdP object id / client id once provisioned" },
        "distinct_from_user": { "type": "boolean", "const": true }
      }
    },
    "credential": {
      "type": "object",
      "required": ["pattern", "shared_secrets_forbidden", "max_lifetime_hours"],
      "properties": {
        "pattern": { "type": "string", "enum": ["oauth2-federated-identity-credential", "managed-identity", "oauth2-client-credentials-keyvault"] },
        "shared_secrets_forbidden": { "type": "boolean", "const": true },
        "max_lifetime_hours": { "type": "number" },
        "local_dev_fallback": { "type": "string", "description": "Must not use shared production credentials." }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["resource", "permission", "environment", "justification"],
        "properties": {
          "resource": { "type": "string" },
          "permission": { "type": "string" },
          "environment": { "type": "string", "enum": ["dev", "test", "prod"] },
          "justification": { "type": "string" }
        }
      }
    },
    "conditional_access": {
      "type": "object",
      "properties": {
        "network_restrictions": { "type": "string" },
        "risk_policies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["provisioning", "rotation", "retirement", "owner"],
      "properties": {
        "provisioning": { "type": "string" },
        "rotation": { "type": "string" },
        "retirement": { "type": "string" },
        "owner": { "type": "string" }
      }
    }
  }
}
